@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h5" Class="ml-3">ACT</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Home" Color="Color.Inherit" Href="/" Class="ml-4" />
        <MudIconButton Icon="@Icons.Material.Filled.MenuBook" Color="Color.Inherit" Href="/dictionaries" Title="Dictionaries" />
    <MudIconButton Icon="@Icons.Material.Filled.Forum" Color="Color.Inherit" Href="/conversations" Title="Conversations" />
    <MudIconButton Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Inherit" Href="/auto-evaluation" Title="Auto Evaluation" />
    <MudIconButton Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Inherit" Href="/batch-evaluation" Title="Batch Evaluation" />
    <MudIconButton Icon="@Icons.Material.Filled.Speed" Color="Color.Inherit" Href="/mcp-usage" Title="MCP Usage" />
    @* <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" Edge="Edge.End" /> *@
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-16">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

