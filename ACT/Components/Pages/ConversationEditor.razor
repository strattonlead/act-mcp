@page "/conversations/new"
@page "/conversations/{Id:guid}"
@using ACT.Models
@using ACT.Services
@using System.Threading
@using System.IO
@inject IConversationService ConversationService
@inject IActService ActService
@inject IActProcessingService ActProcessingService
@inject IFileRepository FileRepository
@inject IS3Service S3Service
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IAutoEvaluationService AutoEvaluationService
@inject IBatchFileStatusService BatchFileStatusService
@inject IChatAgent ChatAgent
@inject IFileParsingService FileParsingService
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">

    @if (_isLoading)
    {
        <div class="d-flex justify-center align-center" style="height: 50vh;">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else
    {
        <MudText Typo="Typo.h4" GutterBottom="true">
            @(_conversation.Id == Guid.Empty ? "New Conversation" : _conversation.Name)
        </MudText>

        <MudGrid>
        <!-- Setup Section -->
        <MudItem xs="12">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6">Setup</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_conversation.Name" Label="Conversation Name" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string" Label="Dictionary" @bind-Value="_conversation.DictionaryKey" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Disabled="@(_conversation.Persons.Any() || _conversation.Situations.Any())">
                            @foreach (var dict in _dictionaries)
                            {
                                <MudSelectItem Value="@dict.Key">@dict.Key</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                         <MudFileUpload T="IBrowserFile" Accept=".txt,.pdf,.docx" FilesChanged="UploadFiles">
                             <ActivatorContent>
                                 <MudButton Variant="Variant.Filled"
                                            Color="Color.Primary"
                                            StartIcon="@Icons.Material.Filled.CloudUpload">
                                     Attach File
                                 </MudButton>
                             </ActivatorContent>
                         </MudFileUpload>
                         @if (_isUploading)
                         {
                             <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="ml-2" />
                         }
                          @if (_attachedFile != null)
                         {
                             <MudChip T="string" Color="Color.Info" Icon="@Icons.Material.Filled.AttachFile" Class="ml-2">@_attachedFile.FileName</MudChip>

                             @if (!AutoEvaluationService.IsProcessing(_conversation.Id))
                             {
                                 var isFirstEval = _conversation.AutoEvalStatus == null && !_conversation.Situations.Any();

                                 @if (isFirstEval)
                                 {
                                     <MudButton Variant="Variant.Filled"
                                                Color="Color.Secondary"
                                                Class="ml-4"
                                                StartIcon="@Icons.Material.Filled.AutoAwesome"
                                                OnClick="StartAutoEval">
                                         Auto Eval
                                     </MudButton>
                                 }
                                 else
                                 {
                                     <MudButton Variant="Variant.Outlined"
                                                Color="@(_conversation.AutoEvalStatus == "Success" ? Color.Default : Color.Warning)"
                                                Class="ml-4"
                                                StartIcon="@Icons.Material.Filled.Refresh"
                                                OnClick="StartAutoEval">
                                         Re-Eval (@_conversation.ProcessedTurns/@_conversation.TotalTurns)
                                     </MudButton>
                                 }
                             }
                         }

                         @if (AutoEvaluationService.IsProcessing(_conversation.Id))
                         {
                             var status = AutoEvaluationService.GetProcessingStatus(_conversation.Id);
                             <div class="d-flex align-center ml-4 gap-2">
                                 <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Secondary" />
                                 <MudText Typo="Typo.caption">@status.Status (@status.Progress%)</MudText>
                             </div>
                         }
                         
                         @{
                             var batchStatus = BatchFileStatusService.GetByConversationId(_conversation.Id);
                             if (batchStatus != null && batchStatus.State != BatchFileState.Completed && batchStatus.State != BatchFileState.Failed)
                             {
                                 <div class="d-flex align-center ml-4 gap-2">
                                     <MudProgressCircular Indeterminate="false" Value="@batchStatus.Progress" Max="100" Size="Size.Small" Color="Color.Success" />
                                     <MudText Typo="Typo.caption">@batchStatus.StatusMessage (@batchStatus.Progress%)</MudText>
                                 </div>
                             }
                         }
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        @if (_conversation.AttachedFileId.HasValue && (!string.IsNullOrEmpty(_conversation.RawText) || _conversation.ParsedMessages.Any()))
        {
            <MudItem xs="12">
                <MudPaper Class="pa-4">
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.h6">Source Content</MudText>
                        <div class="d-flex gap-2 align-center">
                            <MudToggleGroup T="string" @bind-Value="_sourceViewMode" Color="Color.Primary" Size="Size.Small">
                                <MudToggleItem Value="@("turns")" Text="Turns" />
                                <MudToggleItem Value="@("raw")" Text="Raw Text" />
                            </MudToggleGroup>
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReParseTurns"
                                       Disabled="@(_isReparsing || !_conversation.AttachedFileId.HasValue)">
                                @(_isReparsing ? "Re-parsing..." : "Re-parse Turns")
                            </MudButton>
                        </div>
                    </div>

                    @if (_sourceViewMode == "raw" && !string.IsNullOrEmpty(_conversation.RawText))
                    {
                        <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="max-height: 400px; overflow-y: auto; white-space: pre-wrap; font-family: monospace; font-size: 0.85rem;">
                            @_conversation.RawText
                        </MudPaper>
                    }
                    else if (_sourceViewMode == "turns" && _conversation.ParsedMessages.Any())
                    {
                        <div style="max-height: 400px; overflow-y: auto;">
                            @foreach (var msg in _conversation.ParsedMessages.OrderBy(m => m.Order))
                            {
                                <MudPaper Elevation="0" Outlined="true" Class="pa-2 mb-1">
                                    <div class="d-flex gap-2">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled" Style="min-width: 40px;">@msg.Order</MudChip>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@msg.Speaker</MudChip>
                                        <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@msg.Content</MudText>
                                    </div>
                                </MudPaper>
                            }
                        </div>
                        <MudText Typo="Typo.caption" Class="mt-2">@_conversation.ParsedMessages.Count turns parsed</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No source data available. Run Auto Eval to parse the attached file.</MudText>
                    }
                </MudPaper>
            </MudItem>
        }

        <!-- Persons Section -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="height: 100%">
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.h6">Persons</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="OpenAddPersonDialog" Disabled="@string.IsNullOrEmpty(_conversation.DictionaryKey)" />
                </div>
                
                @if (!_conversation.Persons.Any())
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No persons added yet.</MudText>
                }
                else
                {
                    <MudList T="Person" Dense="true">
                        @foreach (var person in _conversation.Persons)
                        {
                            <MudListItem>
                                <MudText><b>@person.Name</b> (@person.Identity)</MudText>
                                <MudText Typo="Typo.caption">@person.Gender</MudText>
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudPaper>
        </MudItem>

        <!-- Events Section -->
        <MudItem xs="12" md="8">
             <MudPaper Class="pa-4" Style="height: 100%">
                <div class="d-flex justify-space-between align-center mb-2">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.h6">Events</MudText>
                        @if (_conversation.TotalTurns > 0)
                        {
                            var evtCount = _conversation.Situations.Sum(s => s.Events?.Count ?? 0);
                            <MudChip T="string" Size="Size.Small" Color="@(_conversation.ProcessedTurns >= _conversation.TotalTurns ? Color.Success : Color.Warning)" Variant="Variant.Outlined">
                                @_conversation.ProcessedTurns/@_conversation.TotalTurns turns | @evtCount events
                            </MudChip>
                        }
                    </div>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddSituation" Disabled="@(!_conversation.Persons.Any())">Add Interaction</MudButton>
                </div>

                @if (!_conversation.Situations.Any())
                {
                     <MudText Typo="Typo.body2" Color="Color.Secondary">Add an interaction or run Auto Eval to generate events.</MudText>
                }
                else
                {
                    <MudExpansionPanels MultiExpansion="true">
                        @foreach (var situation in _conversation.Situations)
                        {
                            <MudExpansionPanel Text="@($"Interaction: {situation.Type}")" IsInitiallyExpanded="true">
                                <TitleContent>
                                    <div class="d-flex align-center gap-4">
                                        <MudText><b>@situation.Type</b></MudText>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@situation.Events.Count Events</MudChip>
                                    </div>
                                </TitleContent>
                                <ChildContent>
                                    <!-- Events List with Original Messages -->
                                    <div class="d-flex flex-column gap-2 mb-4">
                                        @foreach (var evt in situation.Events)
                                        {
                                            <MudCard Elevation="1" Class="pa-2">
                                                @if (!string.IsNullOrEmpty(evt.OriginalMessage))
                                                {
                                                    <MudText Typo="Typo.body2" Class="mb-2 pa-2" Style="background-color: var(--mud-palette-background-gray); border-radius: 4px; font-style: italic; white-space: pre-wrap;">
                                                        @evt.OriginalMessage
                                                    </MudText>
                                                }
                                                <div class="d-flex align-center gap-2">
                                                    <MudText Color="Color.Primary"><b>@evt.Actor.Name</b> (@evt.Actor.Identity)</MudText>
                                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                                                    <MudText Class="font-italic">@evt.Behavior</MudText>
                                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                                                    <MudText Color="Color.Secondary"><b>@evt.Object.Name</b> (@evt.Object.Identity)</MudText>
                                                </div>
                                                @if (evt.Result != null)
                                                {
                                                    <div class="mt-2">
                                                        <MudText Typo="Typo.caption" Class="mb-1"><b>Deflection:</b> @evt.Result.Deflection.ToString("F2")</MudText>
                                                        <div class="d-flex gap-4 flex-wrap">
                                                            @if (evt.Result.TransientActorEPA != null && evt.Result.TransientActorEPA.Length == 3)
                                                            {
                                                                <MudText Typo="Typo.caption"><b>Actor EPA:</b> E=@evt.Result.TransientActorEPA[0].ToString("F2"), P=@evt.Result.TransientActorEPA[1].ToString("F2"), A=@evt.Result.TransientActorEPA[2].ToString("F2")</MudText>
                                                            }
                                                            @if (evt.Result.TransientBehaviorEPA != null && evt.Result.TransientBehaviorEPA.Length == 3)
                                                            {
                                                                <MudText Typo="Typo.caption"><b>Behavior EPA:</b> E=@evt.Result.TransientBehaviorEPA[0].ToString("F2"), P=@evt.Result.TransientBehaviorEPA[1].ToString("F2"), A=@evt.Result.TransientBehaviorEPA[2].ToString("F2")</MudText>
                                                            }
                                                            @if (evt.Result.TransientObjectEPA != null && evt.Result.TransientObjectEPA.Length == 3)
                                                            {
                                                                <MudText Typo="Typo.caption"><b>Object EPA:</b> E=@evt.Result.TransientObjectEPA[0].ToString("F2"), P=@evt.Result.TransientObjectEPA[1].ToString("F2"), A=@evt.Result.TransientObjectEPA[2].ToString("F2")</MudText>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </MudCard>
                                        }
                                    </div>

                                    <!-- Add Event Form -->
                                    <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                                        <MudText Typo="Typo.subtitle2" Class="mb-2">New Event</MudText>
                                        <MudGrid>
                                            <MudItem xs="4">
                                                <MudSelect T="Person" Label="Actor" @bind-Value="_newEventActor" Variant="Variant.Outlined" Dense="true">
                                                    @foreach (var p in _conversation.Persons)
                                                    {
                                                        <MudSelectItem Value="@p">@p.Name</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </MudItem>
                                            <MudItem xs="4">
                                                <MudAutocomplete T="string" Label="Behavior" @bind-Value="_newEventBehavior" SearchFunc="@SearchBehaviors" Variant="Variant.Outlined" Dense="true" />
                                            </MudItem>
                                            <MudItem xs="4">
                                                 <MudSelect T="Person" Label="Object" @bind-Value="_newEventObject" Variant="Variant.Outlined" Dense="true">
                                                    @foreach (var p in _conversation.Persons)
                                                    {
                                                        <MudSelectItem Value="@p">@p.Name</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </MudItem>
                                            <MudItem xs="12" Class="d-flex justify-end">
                                                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" OnClick="@(() => AddEvent(situation))" Disabled="@(!CanAddEvent)">Calculate & Add</MudButton>
                                            </MudItem>
                                        </MudGrid>
                                    </MudPaper>
                                </ChildContent>
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="mt-4 pa-4">
        <MudText Typo="Typo.h6">Deflection Analysis</MudText>
        <div class="d-flex gap-4">
            <div style="flex-grow: 1;">
                 <MudChart ChartType="ChartType.Line" ChartSeries="@_series" XAxisLabels="@_xAxisLabels" ChartOptions="@_chartOptions" Width="100%" Height="350px">
                     <CustomGraphics>
                         @foreach (var block in _situationBlocks)
                         {
                             <rect x="@(block.X.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%" y="0" width="@(block.Width.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%" height="300" fill="@block.Color" opacity="0.1" />
                         }
                     </CustomGraphics>
                 </MudChart>
            </div>
        </div>
        
        <MudDivider Class="my-4" />

        <div class="d-flex justify-space-between align-center mb-2">
            <MudText Typo="Typo.h6">Conversation Timeline</MudText>
            @if (_conversation.Situations.Any())
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Info"
                           StartIcon="@Icons.Material.Filled.OpenInFull" OnClick="@(() => _showTimelineDialog = true)">
                    Expand
                </MudButton>
            }
        </div>
        @{ var allEvents = _conversation.Situations.SelectMany(s => s.Events).ToList(); }
        <div style="overflow-x: auto; white-space: nowrap; padding-bottom: 8px;">
            <MudTimeline TimelineOrientation="TimelineOrientation.Horizontal" TimelinePosition="TimelinePosition.Top">
                @foreach (var evt in allEvents)
                {
                    var deflColor = evt.Result != null
                        ? (evt.Result.Deflection < 4 ? Color.Success : evt.Result.Deflection < 8 ? Color.Warning : Color.Error)
                        : Color.Default;
                    <MudTimelineItem Color="@deflColor" Variant="Variant.Filled">
                        <ItemContent>
                            <MudText Typo="Typo.caption" Style="white-space: normal; min-width: 120px;">
                                <b>@evt.Actor.Name</b> → @evt.Behavior → <b>@evt.Object.Name</b>
                                @if (evt.Result != null)
                                {
                                    <br/><span>D=@evt.Result.Deflection.ToString("F1")</span>
                                }
                            </MudText>
                        </ItemContent>
                    </MudTimelineItem>
                }
            </MudTimeline>
        </div>
    </MudPaper>
    
    <div class="mt-4 d-flex justify-end">
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Cancel" Class="mr-2">Cancel</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="ExportJson" Class="mr-2">Export JSON</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => SaveConversation(true))">Save Conversation</MudButton>
    </div>
    }
</MudContainer>

<!-- Add Person Dialog -->
<MudOverlay @bind-Visible="_isAddPersonOpen" DarkBackground="true" AutoClose="false" ZIndex="9999">
    <MudPaper Class="pa-4" Width="300px">
        <MudText Typo="Typo.h6" GutterBottom="true">Add Person</MudText>
        <MudTextField @bind-Value="_newPersonName" Label="Name" Variant="Variant.Outlined" Class="mb-3" />
        <MudAutocomplete T="string" Label="Identity" @bind-Value="_newPersonIdentity" SearchFunc="@SearchIdentities" Variant="Variant.Outlined" Class="mb-3" />
        <MudSelect T="string" Label="Gender" @bind-Value="_newPersonGender" Variant="Variant.Outlined" Class="mb-4">
            <MudSelectItem Value="@("male")">Male</MudSelectItem>
            <MudSelectItem Value="@("female")">Female</MudSelectItem>
            <MudSelectItem Value="@("average")">Average</MudSelectItem>
        </MudSelect>
        <div class="d-flex justify-end gap-2">
            <MudButton OnClick="@(() => _isAddPersonOpen = false)">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddPerson">Add</MudButton>
        </div>
    </MudPaper>
</MudOverlay>

<!-- Timeline Dialog (vertical, expanded) -->
<MudOverlay @bind-Visible="_showTimelineDialog" DarkBackground="true" AutoClose="true" ZIndex="9999">
    <MudPaper Class="pa-4" Style="max-width: 800px; width: 90vw; max-height: 90vh; overflow-y: auto;">
        <div class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.h5">Conversation Timeline</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showTimelineDialog = false)" />
        </div>
        @{ var dialogEvents = _conversation.Situations.SelectMany(s => s.Events).ToList(); }
        <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
            @foreach (var evt in dialogEvents)
            {
                var dlgDeflColor = evt.Result != null
                    ? (evt.Result.Deflection < 4 ? Color.Success : evt.Result.Deflection < 8 ? Color.Warning : Color.Error)
                    : Color.Default;
                <MudTimelineItem Color="@dlgDeflColor" Variant="Variant.Filled">
                    <ItemContent>
                        <MudCard Elevation="1" Class="pa-2 mb-1">
                            @if (!string.IsNullOrEmpty(evt.OriginalMessage))
                            {
                                <MudText Typo="Typo.body2" Class="mb-1 pa-1" Style="background-color: var(--mud-palette-background-gray); border-radius: 4px; font-style: italic; white-space: pre-wrap;">
                                    @evt.OriginalMessage
                                </MudText>
                            }
                            <div class="d-flex align-center gap-1 flex-wrap">
                                <MudText Color="Color.Primary"><b>@evt.Actor.Name</b></MudText>
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                                <MudText Class="font-italic">@evt.Behavior</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                                <MudText Color="Color.Secondary"><b>@evt.Object.Name</b></MudText>
                                @if (evt.Result != null)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Color="@dlgDeflColor">
                                        D=@evt.Result.Deflection.ToString("F2")
                                    </MudChip>
                                }
                            </div>
                        </MudCard>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    </MudPaper>
</MudOverlay>

@code {
    [Parameter] public Guid? Id { get; set; }

    private Conversation _conversation = new();
    private bool _isLoading = true;
    private List<ActDictionaryDto> _dictionaries = new();
    private List<string> _identities = new();
    private List<string> _behaviors = new();

    // Person Dialog
    private bool _isAddPersonOpen;
    private string _newPersonName;
    private string _newPersonIdentity;
    private string _newPersonGender = "average";

    // New Event Form
    private Person _newEventActor;
    private Person _newEventObject;
    private string _newEventBehavior;

    // File Upload
    private IBrowserFile _uploadedFile;
    private UploadedFile _attachedFile;
    private bool _isUploading;

    // Source content viewer
    private string _sourceViewMode = "turns";
    private bool _isReparsing;

    // Timeline dialog
    private bool _showTimelineDialog;

    // Deflection Graph
    private int _chartIndex = -1;
    private List<ChartSeries> _series = new();
    private string[] _xAxisLabels = { };
    private ChartOptions _chartOptions = new() { YAxisLines = true, ChartPalette = new[] { "#594AE2", "#00C853", "#FFAB00", "#FF1744" } };
    // Colors: Primary (Purple), Green (Likely), Amber (Wait?), Red (Unlikely)
    
    private int _lastBatchProgress = 0;

    // Visualization Blocks
    private class SituationBlock
    {
        public string Name { get; set; }
        public string Color { get; set; }
        public double X { get; set; }
        public double Width { get; set; }
    }
    private List<SituationBlock> _situationBlocks = new();

    protected override async Task OnInitializedAsync()
    {
        AutoEvaluationService.OnProcessingStateChanged += HandleProcessingStateChanged;
        BatchFileStatusService.OnChange += HandleBatchStateChanged;
        _isLoading = true;
        try
        {
            _dictionaries = await ActService.GetDictionariesAsync();

            if (Id.HasValue && Id.Value != Guid.Empty)
            {
                var existing = await ConversationService.GetByIdAsync(Id.Value);
                if (existing != null)
                {
                    _conversation = existing;
                    if (!string.IsNullOrEmpty(_conversation.DictionaryKey))
                    {
                        await LoadDictionaryData(_conversation.DictionaryKey);
                    }
                }
            }
            else
            {
                 _conversation = new Conversation();
            }

            if (_conversation.AttachedFileId.HasValue)
            {
                _attachedFile = await FileRepository.GetByIdAsync(_conversation.AttachedFileId.Value);
            }
            
            UpdateChart();
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        AutoEvaluationService.OnProcessingStateChanged -= HandleProcessingStateChanged;
        BatchFileStatusService.OnChange -= HandleBatchStateChanged;
    }

    private async void HandleProcessingStateChanged(Guid conversationId)
    {
        if (_conversation.Id == conversationId)
        {
            await InvokeAsync(async () => 
            {
                // If finished (not processing anymore), reload the conversation to show results
                if (!AutoEvaluationService.IsProcessing(conversationId))
                {
                    await ReloadConversation();
                }
                StateHasChanged();
            });
        }
    }

    private void HandleBatchStateChanged()
    {
        InvokeAsync(async () => 
        {
            var status = BatchFileStatusService.GetByConversationId(_conversation.Id);
            if (status != null && status.Progress > _lastBatchProgress)
            {
                _lastBatchProgress = status.Progress;
                await ReloadConversation();
            }
            StateHasChanged();
        });
    }
    
    private async Task ReloadConversation()
    {
        if (Id.HasValue)
        {
             var existing = await ConversationService.GetByIdAsync(Id.Value);
             if (existing != null)
             {
                 _conversation = existing;
                 UpdateChart();
             }
        }
    }

    private async Task LoadDictionaryData(string key)
    {
        _identities = await ActService.GetDictionaryIdentitiesAsync(key);
        _behaviors = await ActService.GetDictionaryBehaviorsAsync(key);
    }
    
    private async Task OpenAddPersonDialog()
    {
        if (string.IsNullOrEmpty(_conversation.DictionaryKey))
        {
            Snackbar.Add("Please select a dictionary first.", Severity.Warning);
            return;
        }

        if (!_identities.Any())
        {
            await LoadDictionaryData(_conversation.DictionaryKey);
        }
        
        _newPersonName = $"Person {_conversation.Persons.Count + 1}";
        _newPersonIdentity = "";
        _newPersonGender = "average";
        _isAddPersonOpen = true;
        StateHasChanged();
    }

    private async Task<IEnumerable<string>> SearchIdentities(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return _identities.Take(50);
        return _identities.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase)).Take(50);
    }

    private async Task<IEnumerable<string>> SearchBehaviors(string value, CancellationToken token)
    {
         if (string.IsNullOrEmpty(value)) return _behaviors.Take(50);
        return _behaviors.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase)).Take(50);
    }

    private async Task AddPerson()
    {
        if (string.IsNullOrWhiteSpace(_newPersonName) || string.IsNullOrWhiteSpace(_newPersonIdentity)) return;

        var p = new Person { Name = _newPersonName, Identity = _newPersonIdentity, Gender = _newPersonGender };
        
        if (Id.HasValue) 
        {
            await ConversationService.AddPersonAsync(_conversation.Id, p);
             if (!_conversation.Persons.Any(px => px.Name == p.Name))
             {
                 _conversation.Persons.Add(p);
             }
        }
        else
        {
             _conversation.Persons.Add(p);
        }

        _isAddPersonOpen = false;
    }

    private async Task AddSituation()
    {
        var typeName = "Interaction";
        if (Id.HasValue)
        {
            var s = await ConversationService.AddSituationAsync(_conversation.Id, typeName);
            _conversation.Situations.Add(s);
        }
        else
        {
             _conversation.Situations.Add(new Situation { Type = typeName });
        }
    }

    private bool CanAddEvent => _newEventActor != null && _newEventObject != null && !string.IsNullOrWhiteSpace(_newEventBehavior);

    private async Task AddEvent(Situation situation)
    {
        if (!CanAddEvent) return;

        var interaction = new Interaction
        {
            Actor = _newEventActor,
            Object = _newEventObject,
            Behavior = _newEventBehavior
        };

        try 
        {
            var result = await ActProcessingService.CalculateInteractionAsync(interaction);
            interaction.Result = result;
            
            if (Id.HasValue)
            {
                 await ConversationService.AddEventAsync(_conversation.Id, situation, interaction);
                 var localSit = _conversation.Situations.FirstOrDefault(s => s.Id == situation.Id);
                 if (localSit != null) localSit.Events.Add(interaction);
            }
            else
            {
                 situation.Events.Add(interaction);
            }
            
            _newEventBehavior = "";
            UpdateChart();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Calculation failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveConversation(bool navigateToList)
    {
        if (!Id.HasValue)
        {
             var created = await ConversationService.CreateAsync(_conversation.Name, _conversation.DictionaryKey);
             created.Persons = _conversation.Persons;
             created.Situations = _conversation.Situations;
             created.AttachedFileId = _conversation.AttachedFileId; // Persist attachment
             
             await ConversationService.UpdateAsync(created);
             _conversation = created;
        }
        else
        {
             await ConversationService.UpdateAsync(_conversation);
        }
        
        if (navigateToList)
        {
            NavManager.NavigateTo("/conversations");
        }
    }

    private void Cancel()
    {
        NavManager.NavigateTo("/conversations");
    }

