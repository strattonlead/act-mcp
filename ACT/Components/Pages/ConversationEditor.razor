    private void UpdateChart()
    {
        var data = new List<double>();
        var likelyLine = new List<double>();
        var unlikelyLine = new List<double>();
        var labels = new List<string>();
        int eventCount = 0;
        
        _situationBlocks.Clear();
        
        int totalEvents = _conversation.Situations.Sum(s => s.Events.Where(e => e.Result != null).Count());
        // Even if 0 events, we might want to show empty lines? No, requires data.
        if (totalEvents == 0) return;
        
        double currentXPercent = 0;
        string[] colors = { "#FFCDD2", "#C8E6C9", "#BBDEFB", "#FFF9C4", "#E1BEE7" };
        int colorIdx = 0;

        foreach (var sit in _conversation.Situations)
        {
            int countInSit = sit.Events.Where(e => e.Result != null).Count();
            if (countInSit == 0) continue;
            
            double widthPercent = (double)countInSit / totalEvents * 100.0;
            
            _situationBlocks.Add(new SituationBlock
            {
                Name = sit.Type,
                Color = colors[colorIdx % colors.Length],
                X = currentXPercent,
                Width = widthPercent
            });
            
            currentXPercent += widthPercent;
            colorIdx++;

            foreach (var evt in sit.Events)
            {
                eventCount++;
                if (evt.Result != null)
                {
                    data.Add(evt.Result.Deflection);
                    likelyLine.Add(4.0);
                    unlikelyLine.Add(8.0);
                    labels.Add(eventCount.ToString());
                }
            }
        }
        
        _series.Clear();
        _series.Add(new ChartSeries { Name = "Deflection", Data = data.ToArray() });
        _series.Add(new ChartSeries { Name = "Likely Threshold (< 4.0)", Data = likelyLine.ToArray() });
        _series.Add(new ChartSeries { Name = "Unlikely Threshold (> 8.0)", Data = unlikelyLine.ToArray() });
        
        _xAxisLabels = labels.ToArray();
    }
    private async Task ReParseTurns()
    {
        if (!_conversation.AttachedFileId.HasValue) return;
        _isReparsing = true;
        StateHasChanged();

        try
        {
            // Get raw text: reuse if available, otherwise re-extract from file
            var rawText = _conversation.RawText;
            if (string.IsNullOrEmpty(rawText))
            {
                var uploadedFile = await FileRepository.GetByIdAsync(_conversation.AttachedFileId.Value);
                if (uploadedFile == null) throw new Exception("File not found");
                using var stream = await S3Service.GetFileStreamAsync(uploadedFile.S3BucketName, uploadedFile.S3Key);
                rawText = await FileParsingService.ExtractTextAsync(stream, uploadedFile.FileName);
            }

            // Re-parse with the deterministic + LLM parser
            var parsedMessages = await ChatAgent.ParseMessagesAsync(rawText);

            // Update conversation
            _conversation.RawText = rawText;
            _conversation.ParsedMessages = parsedMessages;
            _conversation.TotalTurns = parsedMessages.Count;
            await ConversationService.UpdateAsync(_conversation);

            Snackbar.Add($"Re-parsed: {parsedMessages.Count} turns found.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Re-parse failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isReparsing = false;
            StateHasChanged();
        }
    }

    private async Task StartAutoEval()
    {
        if (_conversation.Id == Guid.Empty && !_conversation.AttachedFileId.HasValue) return;

        bool isNew = !Id.HasValue;

        // Save first (without navigating to list)
        await SaveConversation(false);

        // Fire evaluation (fire and forget pattern so we can update UI)
        _ = AutoEvaluationService.EvaluateConversationAsync(_conversation.Id);

        // If it was new, we must navigate to the Edit URL to stabilize the component identity
        if (isNew)
        {
            NavManager.NavigateTo($"/conversations/{_conversation.Id}");
        }
        else
        {
            // If existing, just refresh state to show processing
            StateHasChanged();
        }
    }
