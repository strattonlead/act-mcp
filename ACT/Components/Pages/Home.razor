@page "/"

@using ACT.Services
@inject IREnvironmentService RService
@inject IActService ActService
@inject IConversationService ConversationService
@inject NavigationManager NavManager

<div class="d-flex flex-column align-center justify-center mb-8">
    <MudImage Src="img/logo.png" Alt="ACT Logo" Height="256" Class="mb-4" ObjectFit="ObjectFit.Contain" />
    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Affect Control Theory</MudText>
    <MudText Typo="Typo.subtitle1" Align="Align.Center">
        Research and Analysis Tool
    </MudText>
    <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-2">
        Based on the original work at <MudLink Href="https://affectcontroltheory.org" Target="_blank">affectcontroltheory.org</MudLink>
    </MudText>
</div>

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
    <MudText><b>MCP Endpoint:</b> @_mcpUrl</MudText>
</MudAlert>

@if (_isLoading)
{
    <div class="d-flex justify-center my-8">
        <MudStack AlignItems="AlignItems.Center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText>Loading values...</MudText>
        </MudStack>
    </div>
}
else
{
    <MudStack Row="true" Class="mb-4">
        <MudChip T="string" Color="@(_rAvailable ? Color.Success : Color.Error)" Icon="@(_rAvailable ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Error)">
            @(_rAvailable ? "R Runtime Available" : "R Runtime Missing")
        </MudChip>
        @if (_rAvailable)
        {
            <MudChip T="string" Color="Color.Info" Icon="@Icons.Material.Filled.Info">Version: @_rVersion</MudChip>
            @if (_dictionaries != null)
            {
                <MudChip T="string" Color="Color.Primary" Icon="@Icons.Material.Filled.LibraryBooks">Dictionaries: @_dictionaries.Count</MudChip>
            }
        }
    </MudStack>

    @if (_rAvailable && _packageStatuses != null)
    {
        <MudText Typo="Typo.h6" Class="mt-4">R Packages</MudText>
        <MudStack Row="true" Class="mb-4" Wrap="Wrap.Wrap">
            @foreach (var pkg in _packageStatuses)
            {
                <MudChip T="string" Color="@(pkg.IsInstalled ? Color.Success : Color.Error)" Icon="@(pkg.IsInstalled ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)">
                    @pkg.PackageName
                </MudChip>
            }
        </MudStack>
    }

    <MudText Typo="Typo.h6" Class="mt-4">Statistics</MudText>
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="4">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h5">Conversations</MudText>
                    <MudText Typo="Typo.h3">@_conversationCount</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h5">Situations</MudText>
                    <MudText Typo="Typo.h3">@_situationCount</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h5">Events</MudText>
                    <MudText Typo="Typo.h3">@_eventCount</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private bool _isLoading = true;
    private bool _rAvailable;
    private string _rVersion = string.Empty;
    private List<(string PackageName, bool IsInstalled)> _packageStatuses;
    private List<ActDictionaryDto> _dictionaries;
    
    private int _conversationCount;
    private int _situationCount;
    private int _eventCount;
    private string _mcpUrl;

    protected override void OnInitialized()
    {
        var baseUrl = Environment.GetEnvironmentVariable("BASE_URL");
        var useHttpsEnv = Environment.GetEnvironmentVariable("USE_HTTPS");
        var useHttps = string.Equals(useHttpsEnv, "true", StringComparison.OrdinalIgnoreCase);

        if (!string.IsNullOrEmpty(baseUrl))
        {
            // Normalize base url
            baseUrl = baseUrl.TrimEnd('/');
            
            // Handle protocol
            var scheme = useHttps ? "https" : "http";
            
            // If baseUrl already contains scheme, respect it, but if useHttps is true, ensure it is https
            if (baseUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || baseUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            {
                 // If protocol is already there, we might need to replace it if USE_HTTPS is forced?
                 // Usually BASE_URL might just be the domain "example.com" or "api.example.com", or full url.
                 // Let's assume if it has scheme, we trust it, unless USE_HTTPS forces upgrading http to https.
                 if (useHttps && baseUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase))
                 {
                     baseUrl = "https" + baseUrl.Substring(4);
                 }
            }
            else
            {
                // Prepend scheme
                baseUrl = $"{scheme}://{baseUrl}";
            }

            _mcpUrl = $"{baseUrl}/mcp/sse";
        }
        else
        {
            // Fallback to current context
            _mcpUrl = NavManager.ToAbsoluteUri("mcp/sse").ToString();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            (_rAvailable, _rVersion) = await RService.GetRInfoAsync();
            if (_rAvailable)
            {
                _packageStatuses = await RService.GetPackagesStatusAsync();
                _dictionaries = await ActService.GetDictionariesAsync();
            }
            
            var conversations = await ConversationService.GetAllAsync();
            _conversationCount = conversations.Count;
            _situationCount = conversations.Sum(c => c.Situations.Count);
            _eventCount = conversations.SelectMany(c => c.Situations).Sum(s => s.Events.Count);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
